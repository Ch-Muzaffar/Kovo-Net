{
  "name": "kovo-backend",
  "version": "1.0.0",
  "description": "Kovo-Net Knowledge Network — Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node --experimental-websocket src/server.js",
    "dev": "nodemon --exec \"node --experimental-websocket\" src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit --runInBand",
    "test:security": "jest --testPathPattern=tests/security --forceExit --runInBand",
    "lint": "eslint src/ --max-warnings 0",
    "audit": "npm audit --production --audit-level=high",
    "db:push": "echo 'Run src/db/schema.sql in Supabase SQL Editor'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.24.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
