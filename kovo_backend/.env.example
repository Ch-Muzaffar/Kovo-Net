# KOVO NETWORKS Backend Environment Template
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
USE_MOCK_DB=true

# Supabase Credentials (optional when USE_MOCK_DB=true)
SUPABASE_URL=https://mock.supabase.co
SUPABASE_ANON_KEY=mock-anon-key-placeholder
SUPABASE_SERVICE_ROLE_KEY=mock-service-role-key-placeholder
SUPABASE_JWT_SECRET=kovo-local-dev-jwt-secret-change-in-production

# Cloudinary Credentials (optional when USE_MOCK_DB=true)
CLOUDINARY_CLOUD_NAME=mock-cloud-name
CLOUDINARY_API_KEY=mock-api-key
CLOUDINARY_API_SECRET=mock-api-secret
CLOUDINARY_UPLOAD_PRESET=kovo-uploads

# OpenAI Moderation (leave empty to bypass moderation check)
OPENAI_API_KEY=
MODERATION_FAIL_OPEN=true

# Community Game Rules
REPORT_HIDE_THRESHOLD=3
PROFILE_PENALTY_RATE=0.2
BASE_HELPFUL_POINTS=10
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=50
CACHE_TTL_SECONDS=60
ADMIN_EMAILS=admin@kovonet.com
